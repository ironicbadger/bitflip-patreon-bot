# Discord
DISCORD_TOKEN=replace-me
DISCORD_CLIENT_ID=replace-me
DISCORD_GUILD_ID=replace-me

# Patreon
PATREON_ACCESS_TOKEN=
PATREON_CAMPAIGN_ID=

# Recommended: create a Patreon OAuth client, set these values, then visit /oauth/start.
PATREON_CLIENT_ID=
PATREON_CLIENT_SECRET=
PATREON_REFRESH_TOKEN=
PATREON_OAUTH_REDIRECT_URI=http://localhost:3000/oauth/callback
PATREON_OAUTH_SCOPES=identity identity[email] campaigns campaigns.members
PATREON_SETUP_TOKEN=

# Optional fallback for tiers that do not expose discord_role_ids through Patreon.
# Format: patreonTierId:discordRoleId,anotherPatreonTierId:anotherDiscordRoleId
PATREON_TIER_ROLE_MAP=

# Leave false when the official Patreon Discord bot manages roles.
MANAGE_DISCORD_ROLES=false

# Public thank-you announcements for newly active patrons.
ANNOUNCEMENTS_ENABLED=true
ANNOUNCEMENT_CHANNEL_NAME=chit-chat
THANKS_TIER_NAME=terrabyte

# Runtime
DATABASE_PATH=./data/patreon-bot.sqlite
SYNC_INTERVAL_MINUTES=60
SYNC_ON_START=true
DRY_RUN=false
LOG_LEVEL=info

# Webhooks
WEBHOOK_PORT=3000
PATREON_WEBHOOK_SECRET=

# Command access. Administrators are always allowed.
# Format: discordRoleId,anotherDiscordRoleId
COMMAND_ALLOWLIST_ROLE_IDS=
